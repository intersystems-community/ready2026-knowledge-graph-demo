# PlanetCare Demo — Environment Configuration
# Copy to .env and fill in values, or set as shell environment variables

# --- IRIS Connection ---
IRIS_HOST=localhost
IRIS_PORT=11983
IRIS_USERNAME=_SYSTEM
IRIS_PASSWORD=SYS

# --- Embedding Provider ---
# local     = sentence-transformers (all-MiniLM-L6-v2, 384-dim) — DEFAULT, no API key needed
# openai    = OpenAI ada-002 (1536-dim)
# openrouter = OpenRouter (any model)
# custom    = any OpenAI-compatible endpoint
EMBED_PROVIDER=local

# Required if EMBED_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# Required if EMBED_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-...

# Required if EMBED_PROVIDER=custom
# EMBED_BASE_URL=http://localhost:11434/v1
# EMBED_MODEL=nomic-embed-text
# EMBED_DIM=768
# EMBED_API_KEY=none

# --- LLM Provider (for KB synthesis + agent runs) ---
# openai    = OpenAI GPT-4o-mini — DEFAULT
# openrouter = OpenRouter (any model)
# custom    = any OpenAI-compatible endpoint
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# Required if LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# Required if LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-...
# LLM_MODEL=openai/gpt-4o-mini

# Required if LLM_PROVIDER=custom (e.g. local Ollama)
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=none
# LLM_MODEL=llama3.2
